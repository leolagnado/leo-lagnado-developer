---
import { ArrowLeft, FileText } from '@lucide/astro';
import LegalPolicy from './LegalPolicy.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/paths';

interface Props {
  appName: string;
  policyText: string;
  accent: 'coral' | 'gold' | 'violet';
}

const { appName, policyText, accent } = Astro.props;
---

<BaseLayout title={`${appName} Legal Policy`} description={`Complete legal policy for ${appName}.`}>
  <section class="legal-hero">
    <div class="container legal-container">
      <a class="back-link" href={withBase('legal/')}><ArrowLeft size={17} aria-hidden="true" />All legal policies</a>
      <div class="legal-heading">
        <span class="eyebrow"><FileText size={16} aria-hidden="true" />Legal document</span>
        <h1>{appName}</h1>
        <p>This page is an HTML version of the app’s legal policy.</p>
      </div>
    </div>
  </section>
  <section class="legal-document-section">
    <div class="container legal-container">
      <LegalPolicy policyText={policyText} accent={accent} />
    </div>
  </section>
</BaseLayout>

---
import { Clipboard, Mail, ShieldCheck } from '@lucide/astro';
---

<div class="contact-reveal" data-contact-reveal>
  <button class="button button-primary reveal-button" type="button" data-reveal>
    <ShieldCheck size={18} aria-hidden="true" />
    Reveal contact email
  </button>
  <div class="revealed-contact" data-contact hidden aria-live="polite">
    <p class="email-value" data-email></p>
    <div class="contact-actions">
      <button class="button button-secondary" type="button" data-copy>
        <Clipboard size={17} aria-hidden="true" />
        Copy email
      </button>
      <a class="button button-primary" data-mail-link>
        <Mail size={17} aria-hidden="true" />
        Open email app
      </a>
    </div>
    <p class="copy-status" data-copy-status aria-live="polite"></p>
  </div>
</div>

<script>
  const root = document.querySelector<HTMLElement>('[data-contact-reveal]');
  const reveal = root?.querySelector<HTMLButtonElement>('[data-reveal]');
  const contact = root?.querySelector<HTMLElement>('[data-contact]');
  const emailValue = root?.querySelector<HTMLElement>('[data-email]');
  const copy = root?.querySelector<HTMLButtonElement>('[data-copy]');
  const mailLink = root?.querySelector<HTMLAnchorElement>('[data-mail-link]');
  const status = root?.querySelector<HTMLElement>('[data-copy-status]');

  const addressCodes = [
    108, 97, 103, 110, 97, 100, 111, 45, 100, 101, 118, 101, 108, 111, 112, 101,
    114, 64, 111, 117, 116, 108, 111, 111, 107, 46, 99, 111, 109,
  ];

  const getAddress = () => String.fromCharCode(...addressCodes);

  const copyAddress = async (address: string) => {
    if (navigator.clipboard?.writeText) {
      try {
        await navigator.clipboard.writeText(address);
        return;
      } catch {
        // Continue to the local-preview fallback below.
      }
    }

    const field = document.createElement('textarea');
    field.value = address;
    field.setAttribute('readonly', '');
    field.style.position = 'fixed';
    field.style.opacity = '0';
    document.body.append(field);
    field.select();
    const legacyDocument = document as unknown as { execCommand(commandId: string): boolean };
    const copied = legacyDocument.execCommand('copy');
    field.remove();
    if (!copied) throw new Error('Copy command unavailable');
  };

  reveal?.addEventListener('click', () => {
    const address = getAddress();
    if (emailValue) emailValue.textContent = address;
    if (mailLink) mailLink.href = `mailto:${address}`;
    if (contact) contact.hidden = false;
    reveal.hidden = true;
    copy?.focus();
  });

  copy?.addEventListener('click', async () => {
    try {
      await copyAddress(getAddress());
      if (status) status.textContent = 'Email copied.';
    } catch {
      if (status) status.textContent = 'Copy was unavailable. Select the address above to copy it.';
    }
  });
</script>

---
import { ArrowDown, FileText, MapPin, ShieldCheck } from '@lucide/astro';
import AppCard from '../components/AppCard.astro';
import ContactReveal from '../components/ContactReveal.astro';
import { apps } from '../data/apps';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/paths';
---

<BaseLayout>
  <section class="hero">
    <div class="hero-glow hero-glow-one" aria-hidden="true"></div>
    <div class="hero-glow hero-glow-two" aria-hidden="true"></div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Independent developer</p>
        <h1>Apps by Leonardo Mathiazzi Lagnado</h1>
        <p class="hero-tagline">Independent mobile apps for learning, accessibility, and everyday utility.</p>
        <p class="hero-location"><MapPin size={18} aria-hidden="true" />Based in Toronto, Ontario, Canada.</p>
        <div class="hero-actions">
          <a class="button button-primary" href="#apps">View apps<ArrowDown size={18} aria-hidden="true" /></a>
          <a class="button button-secondary" href={withBase('legal/')}><FileText size={18} aria-hidden="true" />Legal policies</a>
        </div>
      </div>
      <div class="hero-icons" aria-label="Developer app icons">
        {apps.map((app, index) => (
          <div class={`hero-icon-wrap hero-icon-${index + 1}`}>
            <span class={`icon-halo accent-${app.accent}`} aria-hidden="true"></span>
            <img src={withBase(app.icon)} alt={`${app.name} app icon`} width="150" height="150" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section apps-section" id="apps" aria-labelledby="apps-title">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Mobile apps</p>
        <h2 id="apps-title">Focused tools, thoughtfully built</h2>
        <p>Explore the current app collection and find official store and legal links.</p>
      </div>
      <div class="app-grid">
        {apps.map((app, index) => <AppCard app={app} index={index} />)}
      </div>
    </div>
  </section>

  <section class="section legal-overview" id="legal" aria-labelledby="legal-title">
    <div class="container legal-overview-grid">
      <div class="section-heading legal-copy">
        <p class="eyebrow"><ShieldCheck size={16} aria-hidden="true" />Clear and accessible</p>
        <h2 id="legal-title">Legal policies</h2>
        <p>Legal policies are available in HTML for review by users, parents, guardians, App Store reviewers, and Google Play reviewers.</p>
        <a class="text-link" href={withBase('legal/')}>View the legal index<ArrowDown class="rotate-link-icon" size={16} aria-hidden="true" /></a>
      </div>
      <div class="legal-card-list">
        {apps.map((app) => (
          <a class="legal-card" href={withBase(app.legalPath)}>
            <img src={withBase(app.icon)} alt="" width="48" height="48" loading="lazy" />
            <span>
              <strong>{app.name} Legal Policy</strong>
              <small>Read the complete HTML policy</small>
            </span>
            <ArrowDown class="rotate-link-icon" size={18} aria-hidden="true" />
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section contact-section" id="contact" aria-labelledby="contact-title">
    <div class="container">
      <div class="contact-panel">
        <div class="contact-copy">
          <p class="eyebrow">Developer contact</p>
          <h2 id="contact-title">Support and inquiries</h2>
          <p>For support, privacy questions, or legal inquiries, use the protected developer contact email below.</p>
        </div>
        <ContactReveal />
      </div>
    </div>
  </section>
</BaseLayout>
